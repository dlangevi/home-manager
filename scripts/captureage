#!/usr/bin/env bash
# On NixOS: uses protontricks-launch --no-bwrap instead of calling Proton directly,
# because NixOS's non-FHS layout prevents Proton from finding system libraries when invoked directly.

APPID=813780
STEAM_PATH="${STEAM_PATH:-$HOME/.local/share/Steam}"

export PROTON_LOG=1
export STEAMAPPS="$STEAM_PATH/steamapps"
export STEAM_COMPAT_DATA_PATH="$STEAMAPPS/compatdata/$APPID"
export STEAM_COMPAT_CLIENT_INSTALL_PATH="$STEAM_PATH"
export WINEPREFIX="$STEAM_COMPAT_DATA_PATH/pfx"
export GAME_DIR="$STEAMAPPS/common/AoE2DE"
export GAME_DIR_WIN='S:\common\AoE2DE'
export CAPTUREAGE_STATE="$WINEPREFIX/drive_c/users/steamuser/AppData/Roaming/CaptureAge/persistedState_prod.json"
export CAPTUREAGE_EXE_WIN='C:\users\steamuser\AppData\Local\Programs\CaptureAge\CaptureAge.exe'
export CAPTUREAGE_EXE="$WINEPREFIX/drive_c/users/steamuser/AppData/Local/Programs/CaptureAge/CaptureAge.exe"
export CAPTUREAGE_DIR_WIN='C:\users\steamuser\AppData\Local\Programs\CaptureAge'
export STEAM_COMPAT_INSTALL_PATH="$GAME_DIR"
export STEAM_COMPAT_LIBRARY_PATHS="$STEAMAPPS"
export PROTON_SET_GAME_DRIVE=1
# export WINEDEBUG=warn+all # This is for debug logs
# export OBS_VKCAPTURE=1 # Enable this for OBS Videogame capture

# On NixOS, jq may not be on PATH — resolve it via nix-shell if needed
if ! command -v jq &>/dev/null; then
  _jq_path=$(nix-shell -p jq --run 'which jq' 2>/dev/null)
  [[ -n "$_jq_path" ]] && export PATH="$(dirname "$_jq_path"):$PATH"
fi

# On NixOS, use protontricks-launch --no-bwrap to run Windows executables.
# Calling Proton directly fails because NixOS lacks /lib/ld-linux.so.2 and 32-bit FreeType.
proton_run() {
  protontricks-launch --no-bwrap --appid "$APPID" "$@"
}

prepare_prefix() {
  local game_dir_win
  local game_dir_escaped

  game_dir_win="$GAME_DIR_WIN"
  game_dir_escaped="${game_dir_win//\\/\\\\}"

  mkdir -p "$WINEPREFIX/dosdevices"
  ln -sfn "$STEAMAPPS" "$WINEPREFIX/dosdevices/s:"

  if [ -f "$WINEPREFIX/user.reg" ]; then
    GAME_DIR_ESCAPED="$game_dir_escaped" perl -0pi -e 'BEGIN{$r=$ENV{GAME_DIR_ESCAPED}} s#"Install Location"="[^"]*"#"Install Location"="$r"#g' "$WINEPREFIX/user.reg"
  fi

  if [ -f "$CAPTUREAGE_STATE" ]; then
    tmp_state="$(mktemp)"
    jq --arg dir "$game_dir_win" '.lastUsedGameDirectory = $dir' "$CAPTUREAGE_STATE" > "$tmp_state" && mv "$tmp_state" "$CAPTUREAGE_STATE"
  fi
}

# Creates Windows registry entries to make the "Spectate with CA" button work
register_captureage() {
  local protocol_command

  protocol_command="\"$CAPTUREAGE_EXE_WIN\" \"%1\""

  for root in HKCU\\Software\\Classes HKLM\\Software\\Classes; do
    proton_run reg add "$root\\captureage" /ve /d "URL:captureage" /f
    proton_run reg add "$root\\captureage" /v "URL Protocol" /d "" /f
    proton_run reg add "$root\\captureage\\shell\\open\\command" /ve /d "$protocol_command" /f
  done

  for root in HKCU HKLM; do
    proton_run reg add "$root\\Software\\Microsoft\\Windows\\CurrentVersion\\App Paths\\CaptureAge.exe" /ve /d "$CAPTUREAGE_EXE_WIN" /f
    proton_run reg add "$root\\Software\\Microsoft\\Windows\\CurrentVersion\\App Paths\\CaptureAge.exe" /v "Path" /d "$CAPTUREAGE_DIR_WIN" /f
  done
}

# Install CaptureAge (only needed once):
#   protontricks-launch --no-bwrap --appid 813780 /S "$HOME/downloads/CaptureAge 1.23.0 Setup.exe"
# (Use /S for silent install — the interactive installer's HTML UI crashes without 32-bit FreeType)

prepare_prefix
register_captureage
# Run CaptureAge
proton_run "$CAPTUREAGE_EXE"
