#!/usr/bin/env python3
"""
Checks /etc/nixos/configuration.nix for sections required by this
home-manager flake. If any are missing, writes a patched version to
/tmp/nixos-configuration.nix and exits 1 with the cp command to run.
"""

import os
import re
import sys

NIXOS_CONFIG = "/etc/nixos/configuration.nix"
TMP_CONFIG = "/tmp/nixos-configuration.nix"


def pubkey():
    path = os.path.expanduser("~/.ssh/id_ed25519.pub")
    try:
        return open(path).read().strip()
    except FileNotFoundError:
        return None


def required_sections():
    sections = [
        {
            "name": "openssh",
            "detect": r"services\.openssh",
            "snippet": """\

  services.openssh = {
    enable = true;
  };
""",
        },
        {
            "name": "avahi",
            "detect": r"services\.avahi",
            "snippet": """\

  services.avahi = {
    enable = true;
    nssmdns4 = true;
    publish = {
      enable = true;
      addresses = true;
    };
  };
""",
        },
    ]

    key = pubkey()
    user = os.environ.get("USER", "")
    if key and user:
        sections.append({
            "name": "authorized_keys",
            "detect": r"authorizedKeys",
            "snippet": f"""
  users.users.{user}.openssh.authorizedKeys.keys = [
    "{key}"
  ];
""",
        })
    elif not key:
        print("Warning: ~/.ssh/id_ed25519.pub not found; skipping authorized_keys check",
              file=sys.stderr)

    return sections


def find_insert_line(lines):
    """Return the 0-based index of the last line that is only '}'."""
    for i in range(len(lines) - 1, -1, -1):
        if re.fullmatch(r"\s*}\s*", lines[i].rstrip("\n")):
            return i
    return len(lines) - 1


def main():
    if not os.path.exists(NIXOS_CONFIG):
        print(f"Error: {NIXOS_CONFIG} not found", file=sys.stderr)
        sys.exit(1)

    content = open(NIXOS_CONFIG).read()
    sections = required_sections()
    missing = [s for s in sections if not re.search(s["detect"], content)]

    if not missing:
        print("All required NixOS sections are present.")
        sys.exit(0)

    print("Missing sections: " + ", ".join(s["name"] for s in missing))

    lines = content.splitlines(keepends=True)
    idx = find_insert_line(lines)

    injected = "\n  # --- added by bootstrap check-nixos ---\n"
    injected += "".join(s["snippet"] for s in missing)

    lines.insert(idx, injected)

    with open(TMP_CONFIG, "w") as f:
        f.write("".join(lines))

    print(f"\nPatched config written to {TMP_CONFIG}")
    print("Review it, then run:")
    print(f"  sudo cp {TMP_CONFIG} {NIXOS_CONFIG} && sudo nixos-rebuild switch")
    sys.exit(1)


if __name__ == "__main__":
    main()
